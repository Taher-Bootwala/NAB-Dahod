# ============================================================
#  Blind School Dahod — Environment Configuration
#  Copy this file to ".env" and fill in your values.
#  The site runs with built-in SEED DATA even if these are blank.
# ============================================================

# --- Supabase (leave blank to use offline seed data) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Storage bucket name for uploaded images
SUPABASE_BUCKET=media

# Per-category Storage buckets (create these in Supabase as PUBLIC buckets)
BUCKET_ACTIVITIES=activities
BUCKET_GALLERY=gallery
BUCKET_TRUSTEES=trustees
BUCKET_HOME=home

# --- Site ---
SITE_NAME="National Association for the Blind, Dahod"
SITE_URL=http://localhost:8000
SITE_ENV=development

# --- Contact / Org details ---
ORG_EMAIL=info@blindschooldahod.org
ORG_PHONE=+91 99999 99999
ORG_WHATSAPP=919999999999
ORG_ADDRESS="National Association for the Blind, Dahod, Godhra Road, Dahod, Gujarat 389151, India"

# --- Donation (UPI QR) ---
UPI_ID=blindschooldahod@upi
UPI_PAYEE_NAME="National Association for the Blind, Dahod"
DONATION_GOAL=2500000

# --- Admin bootstrap (used only by database/seed; real auth via Supabase) ---
ADMIN_EMAIL=admin@blindschooldahod.org

# --- Security ---
APP_SECRET=change-this-to-a-long-random-string
